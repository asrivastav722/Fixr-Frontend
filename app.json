{
  "expo": {
    "name": "Fixr",
    "slug": "fixr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fixr",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.electrolyte.fixr"
    },
    "android": {
      "package": "com.electrolyte.fixr",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}